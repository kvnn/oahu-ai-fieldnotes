{
  "name": "oahu-ai-field-notes",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Vivliostyle book-printing workspace for Oahu AI Field Notes.",
  "scripts": {
    "preview": "vivliostyle preview",
    "build": "vivliostyle build",
    "build:draft": "vivliostyle build",
    "build:proof": "vivliostyle build --config vivliostyle.proof.config.js --crop-marks --bleed 0.13in",
    "build:cover": "node scripts/generate-cover.mjs && vivliostyle build --config vivliostyle.cover.config.js",
    "build:interior": "vivliostyle build --config vivliostyle.database-print.config.js",
    "build:print": "npm run build:cover && npm run build:interior",
    "verify:print": "node scripts/verify-print.mjs",
    "build:print:manuscript": "vivliostyle build --config vivliostyle.print.config.js",
    "clean": "rimraf dist .vivliostyle"
  },
  "devDependencies": {
    "@vivliostyle/cli": "^10.5.0",
    "rimraf": "^6.1.3"
  },
  "engines": {
    "node": ">=20"
  }
}
